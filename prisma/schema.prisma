generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  isVerified Boolean @default(false)
  isBanned  Boolean  @default(false)
  createdAt DateTime @default(now())

  items    Item[]
  bids     Bid[]
  reports  Report[]

  @@map("users")
}

model Item {
  id            String     @id @default(cuid())
  title         String
  description   String?
  category      String
  imageUrl      String?
  startingPrice Float
  currentPrice  Float
  minBidStep    Float      @default(10)
  endTime       DateTime
  status        ItemStatus @default(ACTIVE)
  isFlagged     Boolean    @default(false)
  flagReason    String?
  aiSuggestion  String?
  sellerId      String
  createdAt     DateTime   @default(now())

  seller  User     @relation(fields: [sellerId], references: [id])
  bids    Bid[]
  reports Report[]

  @@map("items")
}

model Bid {
  id        String   @id @default(cuid())
  amount    Float
  itemId    String
  bidderId  String
  createdAt DateTime @default(now())

  item   Item @relation(fields: [itemId], references: [id])
  bidder User @relation(fields: [bidderId], references: [id])

  @@map("bids")
}

model Report {
  id        String   @id @default(cuid())
  reason    String
  itemId    String
  userId    String
  createdAt DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("reports")
}

enum ItemStatus {
  ACTIVE
  ENDED
  CANCELLED
}
