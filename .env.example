# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/auctiondb"

# JWT Secret (change this to a long random string)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Cloudinary (for image uploads) - get free at cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Gemini AI (for image recognition + chatbot) - free at aistudio.google.com
GEMINI_API_KEY="your-gemini-api-key"

# Server
PORT=5000
CLIENT_URL="http://localhost:3000"

# Allowed email domain (university only)
ALLOWED_EMAIL_DOMAIN="paruluniversity.ac.in"
